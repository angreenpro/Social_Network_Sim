graph SocialNetwork {
    graph [
        layout=neato
        overlap=false
        splines=true
        bgcolor="white"
        pad="0.5"
    ];

    node [
        shape=circle
        style=filled
        fillcolor="lightblue"
        fontcolor="black"
        fontname="Arial Bold"
        fontsize=16
        color="#16213e"
        penwidth=1.5
        width=0.6
        height=0.6
    ];

    edge [
        color="#533483"
        penwidth=1.0
    ];

    1 [label="1\nNguyen Van" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    2 [label="2\nTran Thi B" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    3 [label="3\nLe Anh Tu" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    4 [label="4\nPham Thu H" fillcolor="#2ecc71" fontcolor="#1a1a2e" color="#e94560" penwidth=3.0 width=0.9];
    5 [label="5\nVo Anh Duc" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    6 [label="6\nHoang Thi " fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    7 [label="7\nDang Bin" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    8 [label="8\nBui Mai An" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    9 [label="9\nDo Thanh T" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    10 [label="10\nNgo Phuong" fillcolor="#f1c40f" fontcolor="#1a1a2e" color="#e94560" penwidth=3.0 width=0.8];
    11 [label="11\nDuong Van " fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    12 [label="12\nLy Thi Hon" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    13 [label="13\nPham Minh " fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    14 [label="14\nTrinh Gia " fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    15 [label="15\nLe Minh Tr" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    16 [label="16\nTran Van H" fillcolor="#e74c3c" fontcolor="#ffffff" color="#e94560" penwidth=3.0 width=0.9];
    17 [label="17\nHoang Thi " fillcolor="#f1c40f" fontcolor="#1a1a2e" color="#e94560" penwidth=3.0 width=0.8];
    18 [label="18\nLe Minh An" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    19 [label="19\nPham Hoang" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    20 [label="20\nVo Thi Min" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];

    1 -- 10;
    1 -- 20;
    1 -- 7;
    1 -- 4;
    1 -- 3;
    1 -- 15;
    1 -- 2;
    2 -- 13;
    2 -- 11;
    2 -- 8;
    2 -- 5;
    2 -- 3;
    3 -- 20;
    3 -- 9;
    3 -- 5;
    4 -- 10 [color="#e74c3c" penwidth=3.0 style=bold];
    4 -- 19;
    4 -- 6;
    5 -- 20;
    5 -- 19;
    5 -- 13;
    5 -- 9;
    5 -- 8;
    5 -- 15;
    6 -- 20;
    6 -- 19;
    7 -- 20;
    7 -- 19;
    7 -- 16;
    7 -- 12;
    8 -- 14;
    8 -- 11;
    8 -- 15;
    9 -- 14;
    9 -- 16;
    10 -- 15;
    10 -- 17 [color="#e74c3c" penwidth=3.0 style=bold];
    11 -- 19;
    11 -- 15;
    12 -- 14;
    14 -- 15;
    15 -- 17;
    16 -- 17 [color="#e74c3c" penwidth=3.0 style=bold];
}
