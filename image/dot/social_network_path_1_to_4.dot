graph SocialNetwork {
    graph [
        layout=neato
        overlap=false
        splines=true
        bgcolor="white"
        pad="0.5"
    ];

    node [
        shape=circle
        style=filled
        fillcolor="lightblue"
        fontcolor="black"
        fontname="Arial"
        fontsize=16
        color="#16213e"
        penwidth=1.5
        width=0.6
        height=0.6
    ];

    edge [
        color="#533483"
        penwidth=1.0
    ];

    1 [label="1\nNguyen Van" fillcolor="#2ecc71" fontcolor="#1a1a2e" color="#e94560" penwidth=3.0 width=0.9];
    2 [label="2\nTran Thi B" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    3 [label="3\nLe Hoang N" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    4 [label="4\nPham Thu H" fillcolor="#e74c3c" fontcolor="#ffffff" color="#e94560" penwidth=3.0 width=0.9];
    5 [label="5\nVo Minh Du" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    6 [label="6\nHoang Thi " fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    7 [label="7\nDang Quoc " fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    8 [label="8\nBui Ngoc M" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    9 [label="9\nDo Thanh T" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    10 [label="10\nNgo Phuong" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    11 [label="11\nDuong Van " fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];
    12 [label="12\nLy Thi Hon" fillcolor="lightblue" fontcolor="black" color="#16213e" penwidth=1.5 width=0.6];

    1 -- 10;
    1 -- 7;
    1 -- 4 [color="#e74c3c" penwidth=3.0 style=bold];
    1 -- 3;
    1 -- 2;
    2 -- 11;
    2 -- 8;
    2 -- 5;
    2 -- 3;
    3 -- 9;
    3 -- 5;
    4 -- 10;
    4 -- 6;
    5 -- 9;
    5 -- 8;
    7 -- 12;
    8 -- 11;
}
