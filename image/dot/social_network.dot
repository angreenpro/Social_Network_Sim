graph SocialNetwork {
    // Graph attributes
    graph [
        layout=neato
        overlap=false
        splines=true
        bgcolor="white"
        pad="0.5"
    ];

    // Default node style
    node [
        shape=circle
        style=filled
        fillcolor="lightblue"
        fontcolor="black"
        fontname="Arial Bold"
        fontsize=16
        color="#16213e"
        penwidth=1.5
        width=0.6
        height=0.6
    ];

    // Default edge style
    edge [
        color="#533483"
        penwidth=1.0
    ];

    // Nodes
    1 [label="1\nNguyen Van" fillcolor="#f5a623" width=0.8 tooltip="Nguyen Van An | Age: 22 | Ha Noi | Friends: 7"];
    2 [label="2\nTran Thi B" fillcolor="#f5a623" width=0.8 tooltip="Tran Thi Bich | Age: 25 | Ho Chi Minh | Friends: 6"];
    3 [label="3\nLe Anh Tu" fillcolor="#00b4d8" width=0.7 tooltip="Le Anh Tu | Age: 21 | Da Nang | Friends: 5"];
    4 [label="4\nPham Thu H" fillcolor="#00b4d8" width=0.7 tooltip="Pham Thu Huong | Age: 28 | Ha Noi | Friends: 4"];
    5 [label="5\nVo Anh Duc" fillcolor="#e94560" width=0.9 tooltip="Vo Anh Duc | Age: 24 | Can Tho | Friends: 8"];
    6 [label="6\nHoang Thi " fillcolor="lightblue" width=0.6 tooltip="Hoang Thi Lan | Age: 30 | Hue | Friends: 3"];
    7 [label="7\nDang Bin" fillcolor="#00b4d8" width=0.7 tooltip="Dang Bin | Age: 19 | Ha Noi | Friends: 5"];
    8 [label="8\nBui Mai An" fillcolor="#00b4d8" width=0.7 tooltip="Bui Mai Anh | Age: 26 | Ho Chi Minh | Friends: 5"];
    9 [label="9\nDo Thanh T" fillcolor="#00b4d8" width=0.7 tooltip="Do Thanh Tung | Age: 23 | Da Nang | Friends: 4"];
    10 [label="10\nNgo Phuong" fillcolor="#00b4d8" width=0.7 tooltip="Ngo Phuong Linh | Age: 27 | Ha Noi | Friends: 4"];
    11 [label="11\nDuong Van " fillcolor="#00b4d8" width=0.7 tooltip="Duong Van Hieu | Age: 31 | Ho Chi Minh | Friends: 4"];
    12 [label="12\nLy Thi Hon" fillcolor="lightblue" width=0.6 tooltip="Ly Thi Hong | Age: 20 | Hai Phong | Friends: 2"];
    13 [label="13\nPham Minh " fillcolor="lightblue" width=0.6 tooltip="Pham Minh Anh | Age: 24 | Ha Noi | Friends: 2"];
    14 [label="14\nTrinh Gia " fillcolor="#00b4d8" width=0.7 tooltip="Trinh Gia Huy | Age: 28 | Ho Chi Minh | Friends: 4"];
    15 [label="15\nLe Minh Tr" fillcolor="#f5a623" width=0.8 tooltip="Le Minh Trang | Age: 22 | Da Nang | Friends: 7"];
    16 [label="16\nTran Van H" fillcolor="lightblue" width=0.6 tooltip="Tran Van Hung | Age: 29 | Ha Noi | Friends: 3"];
    17 [label="17\nHoang Thi " fillcolor="lightblue" width=0.6 tooltip="Hoang Thi Minh | Age: 26 | Ho Chi Minh | Friends: 3"];
    18 [label="18\nLe Minh An" fillcolor="lightblue" width=0.6 tooltip="Le Minh Anh | Age: 23 | Da Nang | Friends: 0"];
    19 [label="19\nPham Hoang" fillcolor="#00b4d8" width=0.7 tooltip="Pham Hoang Anh | Age: 27 | Ha Noi | Friends: 5"];
    20 [label="20\nVo Thi Min" fillcolor="#00b4d8" width=0.7 tooltip="Vo Thi Minh | Age: 25 | Ho Chi Minh | Friends: 5"];

    // Edges
    1 -- 10;
    1 -- 20;
    1 -- 7;
    1 -- 4;
    1 -- 3;
    1 -- 15;
    1 -- 2;
    2 -- 13;
    2 -- 11;
    2 -- 8;
    2 -- 5;
    2 -- 3;
    3 -- 20;
    3 -- 9;
    3 -- 5;
    4 -- 10;
    4 -- 19;
    4 -- 6;
    5 -- 20;
    5 -- 19;
    5 -- 13;
    5 -- 9;
    5 -- 8;
    5 -- 15;
    6 -- 20;
    6 -- 19;
    7 -- 20;
    7 -- 19;
    7 -- 16;
    7 -- 12;
    8 -- 14;
    8 -- 11;
    8 -- 15;
    9 -- 14;
    9 -- 16;
    10 -- 15;
    10 -- 17;
    11 -- 19;
    11 -- 15;
    12 -- 14;
    14 -- 15;
    15 -- 17;
    16 -- 17;
}
